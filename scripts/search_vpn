#!/usr/bin/env bash

# Script to select and run an OpenVPN client config using rofi
# Credentials are stored encrypted via pass (GPG), e.g.:
#   pass insert vpn/protonvpn-username
#   pass insert vpn/protonvpn-password

CLIENTS_DIR="/etc/openvpn/client"
PASS_USERNAME_KEY="vpn/proton/ikev2/username"
PASS_PASSWORD_KEY="vpn/proton/ikev2/password"

DISCONNECT_LABEL="Disconnect All"

# Find available .ovpn config files
available_configs=$(find "$CLIENTS_DIR" -type f -name "*.ovpn" 2>/dev/null)

if [[ -z "$available_configs" ]]; then
    notify-send "OpenVPN" "No client configs found in $CLIENTS_DIR"
    exit 1
fi

# Strip path and extension for display
filtered_configs=$(echo "$available_configs" | sed 's|.*/||; s|\.ovpn$||')

# Prepend disconnect option to menu
menu=$(printf '%s\n%s' "$DISCONNECT_LABEL" "$filtered_configs")

# Let user pick a config
selection=$(echo "$menu" | rofi -dmenu -p "Select VPN client:")

if [[ -z "$selection" ]]; then
    exit 0
fi

# Handle disconnect
if [[ "$selection" == "$DISCONNECT_LABEL" ]]; then
    sudo killall openvpn 2>/dev/null
    if [[ $? -eq 0 ]]; then
        notify-send "OpenVPN" "All VPN connections disconnected"
    else
        notify-send "OpenVPN" "No active VPN connections found"
    fi
    exit 0
fi

if [[ -z "$selection" ]]; then
    exit 0
fi

CONFIG_FILE="$CLIENTS_DIR/$selection.ovpn"

if [[ ! -f "$CONFIG_FILE" ]]; then
    notify-send "OpenVPN" "Config file not found: $CONFIG_FILE"
    exit 1
fi

# Retrieve credentials via pass (GPG decryption happens here)
# Your GPG key must be unlocked (e.g. via gpg-agent on login)
VPN_USER=$(pass "$PASS_USERNAME_KEY" 2>/dev/null)
VPN_PASS=$(pass "$PASS_PASSWORD_KEY" 2>/dev/null)

if [[ -z "$VPN_USER" || -z "$VPN_PASS" ]]; then
    notify-send "OpenVPN" "Failed to retrieve credentials from pass"
    exit 1
fi

# Write credentials to a temp file (openvpn --auth-user-pass expects a file)
CRED_FILE=$(mktemp /tmp/ovpn-creds.XXXXXX)
chmod 600 "$CRED_FILE"
printf '%s\n%s\n' "$VPN_USER" "$VPN_PASS" > "$CRED_FILE"

# Write credentials to a temp file
CRED_FILE=$(mktemp /tmp/ovpn-creds.XXXXXX)
chmod 600 "$CRED_FILE"
printf '%s\n%s\n' "$VPN_USER" "$VPN_PASS" > "$CRED_FILE"

notify-send "OpenVPN" "Connecting to $selection..."

sudo openvpn --config "$CONFIG_FILE" --auth-user-pass "$CRED_FILE" \
    --log /tmp/openvpn-"$selection".log --daemon

EXIT_CODE=$?

# Give openvpn a moment to read the creds before deleting
sleep 3 && rm -f "$CRED_FILE" &

if [[ $EXIT_CODE -eq 0 ]]; then
    notify-send "OpenVPN" "Connected to $selection (daemonized)"
else
    notify-send "OpenVPN" "Failed to connect to $selection â€” check /tmp/openvpn-$selection.log"
fi
